{
  "name": "asset-organizer-mvp",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "concurrently \"npm run dev -- --port 5173\" \"wait-on http://127.0.0.1:5173 && electron . --dev\"",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "dist": "npm run build && powershell -ExecutionPolicy Bypass -File scripts/package-win.ps1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "playwright": "^1.61.0",
    "wait-on": "^9.0.10"
  }
}
